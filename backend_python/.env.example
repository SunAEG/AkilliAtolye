# Ortam değişkenlerini buraya kopyalayıp .env olarak kaydedin.
# Üretimde bu değerleri güvenli bir secret manager'dan alın!

# --- Uygulama ---
APP_NAME="AkilliAtolye Backend"
APP_VERSION="0.1.0"
DEBUG=True

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=akilliatolye_user
POSTGRES_PASSWORD=akilliatolye_password
POSTGRES_DB=akilliatolye_db

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=akilliatolye_user
RABBITMQ_PASSWORD=akilliatolye_password
RABBITMQ_VHOST=/
